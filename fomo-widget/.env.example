# FOMO-WIDGET environment variables
# Copy to .env and fill in your keys

VITE_LUMA_API_KEY=       # lu.ma/developers — falls back to 10 seeded mock events without it
VITE_MAPBOX_TOKEN=       # optional — Leaflet+OpenStreetMap works without it
VITE_GOOGLE_CLIENT_ID=   # for Google Calendar OAuth — not needed if using Calendar MCP

# ANTHROPIC_API_KEY — NOT NEEDED
# Claude Code is a local subprocess (spawn('claude')), not an API call
